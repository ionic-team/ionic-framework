{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowUnreachableCode": false,
    "lib": ["es2017", "dom"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "sourceMap": false,
    "pretty": true,
    "rootDir": "schematics",
    "target": "es2017",
    "outDir": "dist/schematics",
    // TypeScript 6.0 defaults `types` to []; the devkit .d.ts the schematics
    // consume reference Node globals (Buffer, node:url), so opt them back in.
    "types": ["node"]
  },
  "exclude": ["node_modules"],
  "include": ["schematics/**/*.ts"]
}
