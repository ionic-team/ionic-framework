{
  "name": "ionic-angular-test-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "sync:build": "sh scripts/build-ionic.sh",
    "sync": "sh scripts/sync.sh",
    "build": "ng build --configuration production --no-progress",
    "lint": "ng lint",
    "serve:ssr": "node dist/test-app/server/main.js",
    "build:ssr": "ng build --prod && ng run test-app:server:production",
    "dev:ssr": "ng run test-app:serve-ssr",
    "prerender": "ng run test-app:prerender",
    "test": "npx playwright test"
  },
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "@ionic/angular": "^8.4.0",
    "@ionic/angular-server": "^8.4.0",
    "core-js": "^3.33.2",
    "express": "^4.18.2",
    "ionicons": "^8.0.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0",
    "typescript-eslint-language-service": "^4.1.5"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.0",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/language-service": "^22.0.0",
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.3",
    "@types/ws": "8.5.3",
    "angular-eslint": "^22.0.0",
    "concurrently": "^6.0.0",
    "eslint": "^9.0.0",
    "ts-loader": "^6.2.2",
    "ts-node": "^8.3.0",
    "typescript": "~6.0.0",
    "wait-on": "^8.0.1",
    "webpack": "^5.61.0",
    "webpack-cli": "^4.9.2"
  },
  "engines": {
    "node": ">=22.22.3"
  }
